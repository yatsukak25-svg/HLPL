@page
@model TutorFlow.Areas.Identity.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Вихід";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm mt-5">
            <div class="card-body p-4 text-center">
                <h1 class="h3 mb-3">@ViewData["Title"]</h1>
                <p>Ви впевнені, що хочете вийти?</p>
                <form method="post">
                    <button type="submit" class="btn btn-danger w-100 py-2">Так, вийти</button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary w-100 py-2 mt-2">Скасувати</a>
                </form>
            </div>
        </div>
    </div>
</div>
