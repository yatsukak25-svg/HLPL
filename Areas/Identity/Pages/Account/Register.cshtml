@page
@model TutorFlow.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Реєстрація";
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">@ViewData["Title"]</h1>
                <p class="text-muted">Створіть свій особистий кабінет для навчання або викладання.</p>

                <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Role Selection -->
                    <div class="mb-4">
                        <label asp-for="Input.Role" class="form-label fw-bold"></label>
                        <div class="row g-2">
                            <div class="col-6">
                                <input type="radio" class="btn-check" asp-for="Input.Role" value="Student" id="roleStudent" checked autocomplete="off">
                                <label class="btn btn-outline-primary w-100 py-3" for="roleStudent">
                                    <i class="bi bi-mortarboard fs-4 d-block mb-1"></i>
                                    Я Учень/Учениця
                                </label>
                            </div>
                            <div class="col-6">
                                <input type="radio" class="btn-check" asp-for="Input.Role" value="Tutor" id="roleTutor" autocomplete="off">
                                <label class="btn btn-outline-primary w-100 py-3" for="roleTutor">
                                    <i class="bi bi-person-workspace fs-4 d-block mb-1"></i>
                                    Я Репетитор
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.FullName" class="form-label"></label>
                        <input asp-for="Input.FullName" class="form-control" placeholder="Іван Іванов" />
                        <span asp-validation-for="Input.FullName" class="text-danger"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Input.Email" class="form-label"></label>
                            <input asp-for="Input.Email" class="form-control" placeholder="example@mail.com" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.PhoneNumber" class="form-label"></label>
                            <input asp-for="Input.PhoneNumber" class="form-control" placeholder="+380XXXXXXXXX" />
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label asp-for="Input.Password" class="form-label"></label>
                            <input asp-for="Input.Password" class="form-control" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                            <input asp-for="Input.ConfirmPassword" class="form-control" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <div id="studentFields" class="mt-3">
                        <div class="mb-3">
                            <label asp-for="Input.Grade" class="form-label"></label>
                            <select asp-for="Input.Grade" class="form-select">
                                <option value="">Оберіть клас...</option>
                                @for (int i = 1; i <= 12; i++)
                                {
                                    <option value="@i">@i клас</option>
                                }
                            </select>
                            <span asp-validation-for="Input.Grade" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 mt-3">
                        <label asp-for="Input.Notes" class="form-label" id="notesLabel">Нотатки</label>
                        <textarea asp-for="Input.Notes" class="form-control" rows="3" placeholder="Додаткова інформація..."></textarea>
                        <span asp-validation-for="Input.Notes" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 mt-4 shadow-sm fw-bold">Зареєструватися</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const roleStudent = document.getElementById('roleStudent');
            const roleTutor = document.getElementById('roleTutor');
            const studentFields = document.getElementById('studentFields');
            const notesLabel = document.getElementById('notesLabel');
            const notesInput = document.querySelector('textarea[name="Input.Notes"]');

            function toggleFields() {
                if (roleTutor.checked) {
                    studentFields.classList.add('d-none');
                    notesLabel.textContent = 'Про себе / Досвід викладання';
                    notesInput.placeholder = 'Розкажіть про свій досвід, освіту та предмети, які викладаєте...';
                } else {
                    studentFields.classList.remove('d-none');
                    notesLabel.textContent = 'Нотатки / Побажання';
                    notesInput.placeholder = 'Додаткова інформація для репетитора...';
                }
            }

            roleStudent.addEventListener('change', toggleFields);
            roleTutor.addEventListener('change', toggleFields);
            
            // Initial call
            toggleFields();
        });
    </script>
}
