@model HLPL_lab_1.Models.BookingViewModel
@{
    ViewData["Title"] = "Підтвердження бронювання";
    var totalPrice = ViewData["TotalPrice"] is decimal price ? price : 0m;
}

<style>
    .confirmation-card {
        background: rgba(255, 252, 247, 0.98);
        color: #1f2937;
        border: 1px solid rgba(184, 140, 64, 0.22);
        border-radius: 24px;
        padding: 2.2rem;
        box-shadow: 0 18px 42px rgba(28, 23, 43, 0.12);
    }

    .confirmation-title {
        color: #14213d;
        font-size: 2.2rem;
        font-weight: 800;
    }

    .confirmation-meta {
        color: #52607a;
    }

    .confirmation-accent {
        color: #9a3412;
        font-weight: 700;
    }
</style>

<div class="container py-5">
    <div class="confirmation-card">
        <h1 class="confirmation-title">Бронювання підтверджено</h1>
        <p class="confirmation-meta mt-3">
            Заявку для <span class="confirmation-accent">@Model.CustomerName</span> прийнято.
        </p>

        <div class="row g-3 mt-2">
            <div class="col-md-6">
                <div><strong>Фільм:</strong> @Model.MovieTitle</div>
                <div><strong>Сеанс:</strong> @Model.Showtime</div>
                <div><strong>Квитків:</strong> @Model.TicketCount</div>
            </div>
            <div class="col-md-6">
                <div><strong>Телефон:</strong> @Model.PhoneNumber</div>
                <div><strong>Коментар:</strong> @(string.IsNullOrWhiteSpace(Model.Comment) ? "не вказано" : Model.Comment)</div>
                <div><strong>Сума:</strong> @totalPrice.ToString("0") грн</div>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <a class="btn btn-outline-dark rounded-pill px-4" asp-controller="Booking" asp-action="Index">Нове бронювання</a>
            <a class="btn btn-warning rounded-pill px-4" asp-controller="Home" asp-action="Schedule">До розкладу</a>
        </div>
    </div>
</div>
