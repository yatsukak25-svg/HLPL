@model HLPL_lab_1.Models.BookingViewModel
@{
    ViewData["Title"] = "Бронювання";
    var ticketPrice = ViewData["TicketPrice"] is decimal price ? price : 0m;
    var availableSeats = ViewData["AvailableSeats"] is int seats ? seats : 0;
    var bookingHint = ViewData["BookingHint"]?.ToString() ?? string.Empty;
    var movieScheduleJson = ViewData["MovieScheduleJson"]?.ToString() ?? "{}";
}

<style>
    .booking-shell {
        color: #1f2937;
    }

    .booking-hero,
    .booking-card,
    .booking-summary {
        background: rgba(255, 252, 247, 0.97);
        border: 1px solid rgba(184, 140, 64, 0.22);
        border-radius: 24px;
        box-shadow: 0 18px 42px rgba(28, 23, 43, 0.12);
    }

    .booking-hero {
        padding: 2.2rem;
    }

    .booking-title {
        color: #14213d;
        font-size: 2.4rem;
        font-weight: 800;
        margin-bottom: 0.75rem;
    }

    .booking-lead {
        color: #44506a;
        font-size: 1.05rem;
        max-width: 720px;
    }

    .booking-card {
        padding: 2rem;
    }

    .booking-summary {
        padding: 1.5rem;
        height: 100%;
    }

    .summary-value {
        color: #14213d;
        font-size: 1.6rem;
        font-weight: 700;
    }

    .summary-label,
    .booking-note {
        color: #5b6478;
    }

    .booking-badge {
        display: inline-block;
        margin-right: 0.6rem;
        margin-bottom: 0.6rem;
        padding: 0.4rem 0.85rem;
        border-radius: 999px;
        background: #fff1cf;
        color: #6b4c12;
        font-weight: 600;
    }

    .booking-form label {
        color: #1b2741;
        font-weight: 600;
        margin-bottom: 0.45rem;
    }

    .booking-form .form-control,
    .booking-form .form-select {
        border-radius: 14px;
        border-color: #cbd5e1;
        padding: 0.8rem 0.95rem;
        color: #172033;
        background: #ffffff;
    }

    .booking-form .form-control:focus,
    .booking-form .form-select:focus {
        border-color: #c98d24;
        box-shadow: 0 0 0 0.2rem rgba(201, 141, 36, 0.18);
    }

    .booking-submit {
        background: #9a3412;
        border: none;
        color: #fff;
        font-weight: 700;
        padding: 0.8rem 1.5rem;
        border-radius: 999px;
    }

    .booking-submit:hover {
        background: #7c2d12;
        color: #fff;
    }

    .field-validation-error,
    .validation-summary-errors {
        color: #b42318;
    }
</style>

<div class="container py-5 booking-shell">
    <section class="booking-hero mb-4">
        <div class="row g-4 align-items-center">
            <div class="col-lg-8">
                <h1 class="booking-title">Бронювання квитків</h1>
                <p class="booking-lead mb-3">@bookingHint</p>
                <div>
                    <span class="booking-badge">Ціна квитка: @ticketPrice.ToString("0") грн</span>
                    <span class="booking-badge">Вільних місць сьогодні: @availableSeats</span>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="booking-summary">
                    <div class="summary-label">Новий розділ для ЛР2</div>
                    <div class="summary-value mt-2">MVC + форма</div>
                    <p class="booking-note mt-3 mb-0">
                        Тут модель передається з контролера у представлення, а після відправки форми повертається назад у контролер.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="row g-4">
        <div class="col-lg-8">
            <div class="booking-card">
                <form asp-action="Index" asp-controller="Booking" method="post" class="booking-form">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CustomerName"></label>
                            <input asp-for="CustomerName" class="form-control" placeholder="Ваше ім'я" />
                            <span asp-validation-for="CustomerName"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber"></label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+380..." />
                            <span asp-validation-for="PhoneNumber"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MovieTitle"></label>
                            <select asp-for="MovieTitle" class="form-select" id="movieSelect">
                                @foreach (var movie in Model.AvailableMovies)
                                {
                                    <option value="@movie">@movie</option>
                                }
                            </select>
                            <span asp-validation-for="MovieTitle"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Showtime"></label>
                            <select asp-for="Showtime" class="form-select" id="showtimeSelect">
                                @foreach (var showtime in Model.AvailableShowtimes)
                                {
                                    <option value="@showtime">@showtime</option>
                                }
                            </select>
                            <span asp-validation-for="Showtime"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="TicketCount"></label>
                            <input asp-for="TicketCount" class="form-control" min="1" max="10" />
                            <span asp-validation-for="TicketCount"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Comment"></label>
                            <input asp-for="Comment" class="form-control" placeholder="Побажання до замовлення" />
                            <span asp-validation-for="Comment"></span>
                        </div>
                    </div>

                    <button type="submit" class="booking-submit mt-4">Підтвердити бронювання</button>
                </form>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="booking-summary">
                <div class="summary-label">Що перевіряє ця сторінка</div>
                <ul class="mt-3 mb-0">
                    <li>новий пункт меню</li>
                    <li>окремий контролер `BookingController`</li>
                    <li>рядок і число з контролера у view</li>
                    <li>передача моделі в обидва боки</li>
                </ul>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const movieSchedule = @Html.Raw(movieScheduleJson);
        const movieSelect = document.getElementById('movieSelect');
        const showtimeSelect = document.getElementById('showtimeSelect');

        function syncShowtimes() {
            const showtimes = movieSchedule[movieSelect.value] || [];
            const currentValue = showtimeSelect.value;
            showtimeSelect.innerHTML = '';

            showtimes.forEach(showtime => {
                const option = document.createElement('option');
                option.value = showtime;
                option.textContent = showtime;
                if (showtime === currentValue) {
                    option.selected = true;
                }
                showtimeSelect.appendChild(option);
            });

            if (!showtimes.includes(currentValue) && showtimes.length > 0) {
                showtimeSelect.value = showtimes[0];
            }
        }

        movieSelect.addEventListener('change', syncShowtimes);
        syncShowtimes();
    </script>
}
