@{
    ViewData["Title"] = "Календар занять";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h2 class="fw-bold"><i class="bi bi-calendar3 me-2 text-primary"></i>@ViewData["Title"]</h2>
        <p class="text-muted">Керуйте своїм розкладом та відстежуйте статуси занять у реальному часі.</p>
    </div>
    <div class="col-md-4 text-md-end d-flex align-items-center justify-content-md-end">
        @if (User.IsInRole("Tutor") || User.IsInRole("Admin"))
        {
            <a asp-controller="Lessons" asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg me-1"></i>Нове заняття
            </a>
        }
    </div>
</div>

<div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4">
    <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
        <div class="d-flex gap-3">
            <div class="d-flex align-items-center"><span class="badge rounded-pill bg-primary me-1">&nbsp;</span> <small>Заплановано</small></div>
            <div class="d-flex align-items-center"><span class="badge rounded-pill bg-success me-1">&nbsp;</span> <small>Проведено</small></div>
            <div class="d-flex align-items-center"><span class="badge rounded-pill bg-danger me-1">&nbsp;</span> <small>Скасовано</small></div>
        </div>
    </div>
    <div class="card-body p-4" style="background: #fafafa;">
        <div id="calendar" style="background: white; border-radius: 12px; padding: 10px; box-shadow: inset 0 0 10px rgba(0,0,0,0.02);"></div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/main.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var calendarEl = document.getElementById('calendar');
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                locale: 'uk',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                buttonText: {
                    today: 'Сьогодні',
                    month: 'Місяць',
                    week: 'Тиждень',
                    day: 'День'
                },
                events: '/Calendar/GetEvents',
                eventClick: function(info) {
                    window.location.href = '/Lessons/Edit/' + info.event.id;
                },
                firstDay: 1,
                height: 650,
                contentHeight: 600,
                expandRows: true,
                handleWindowResize: true
            });
            calendar.render();
        });
    </script>
    
    <style>
        #calendar { min-height: 600px; }
        .fc-event { cursor: pointer; padding: 4px 6px; border-radius: 6px !important; margin: 1px 0; font-size: 0.85rem; }
        .fc-toolbar-title { font-size: 1.4rem !important; font-weight: 700; color: #17304a; }
        .fc-button-primary { background-color: #d66b36 !important; border-color: #d66b36 !important; text-transform: capitalize; }
        .fc-button-primary:hover { background-color: #b65220 !important; }
        .fc-button-active { background-color: #17304a !important; border-color: #17304a !important; }
        .fc-daygrid-day-number { font-weight: 600; color: #444; }
        .fc-col-header-cell { background: #f8f9fa; padding: 10px 0 !important; color: #666; font-weight: 700; text-transform: uppercase; font-size: 0.75rem; }
    </style>
}
