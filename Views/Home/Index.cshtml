@{
    ViewData["Title"] = "Кінопалац Рівне";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:wght@400;600&display=swap');

    :root {
        --ink: #12121a;
        --gold: #f5c466;
        --copper: #e86f4b;
        --deep: #1e1a3a;
        --teal: #0f6b6a;
        --sky: #eaf7ff;
        --paper: #fff7ec;
    }

    .cinema-hero {
        background: linear-gradient(120deg, rgba(18, 18, 26, 0.92), rgba(30, 26, 58, 0.92)), url('/img/noise.svg');
        color: #fff;
        border-radius: 28px;
        padding: 3.5rem;
        box-shadow: 0 25px 60px rgba(18, 18, 26, 0.35);
    }

    .brand-title {
        font-family: "Bebas Neue", sans-serif;
        font-size: 3.5rem;
        letter-spacing: 0.15rem;
    }

    .brand-subtitle {
        font-family: "Cormorant Garamond", serif;
        font-size: 1.2rem;
        max-width: 700px;
    }

    .section-title {
        font-family: "Bebas Neue", sans-serif;
        font-size: 2.2rem;
        letter-spacing: 0.08rem;
        color: var(--deep);
    }

    .movie-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 18px 50px rgba(32, 24, 69, 0.12);
        border: none;
        overflow: hidden;
    }

    .movie-poster {
        width: 100%;
        height: 320px;
        object-fit: cover;
        display: block;
    }

    .movie-meta {
        font-size: 0.9rem;
        color: #6c6f7a;
    }

    .showtime-pill {
        background: var(--sky);
        color: var(--teal);
        border-radius: 999px;
        padding: 0.2rem 0.7rem;
        font-size: 0.8rem;
        margin-right: 0.35rem;
        margin-bottom: 0.35rem;
        display: inline-block;
    }

    .service-card {
        background: #ffffff;
        border-radius: 18px;
        padding: 1.5rem;
        border: 1px solid rgba(30, 26, 58, 0.08);
        height: 100%;
    }

    .cta-button {
        background: var(--copper);
        border: none;
        color: #fff;
        padding: 0.6rem 1.4rem;
        border-radius: 999px;
        font-weight: 600;
    }

    .cta-button:hover {
        color: #fff;
        box-shadow: 0 10px 25px rgba(232, 111, 75, 0.35);
    }

    .contact-box {
        background: #ffffff;
        border-radius: 20px;
        padding: 1.8rem;
        box-shadow: 0 18px 45px rgba(20, 26, 58, 0.1);
    }

    .note {
        font-size: 0.9rem;
        color: #6b6f82;
    }
</style>

<div class="container py-5">
    <section class="cinema-hero mb-5">
        <div class="row align-items-center g-4">
            <div class="col-lg-8">
                <h1 class="brand-title">КІНОПАЛАЦ РІВНЕ</h1>
                <p class="brand-subtitle">
                    Оновлена афіша на основі даних з kino.rv.ua: фільми у прокаті, сеанси та контакти кінотеатру.
                </p>
                <div class="d-flex flex-wrap gap-3 mt-4">
                    <a class="cta-button text-decoration-none" asp-controller="Home" asp-action="Schedule">Перейти до розкладу</a>
                </div>
            </div>
            <div class="col-lg-4 text-lg-end">
                <div class="display-6 fw-bold" style="color: var(--gold);">Сеанси дня</div>
                <div class="fs-5">10:00 · 12:00 · 14:50 · 17:30 · 20:40</div>
            </div>
        </div>
    </section>

    <section class="mb-5">
        <h2 class="section-title mb-3">Фільми у прокаті</h2>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="movie-card h-100">
                    <img class="movie-poster" src="/images/posters/mufasa.svg" alt="Афіша Муфаса: Король Лев">
                    <div class="p-3">
                    <h5 class="fw-bold">Муфаса: Король Лев</h5>
                    <div class="movie-meta mb-2">3D · Українська</div>
                    <div><span class="showtime-pill">12:00</span><span class="showtime-pill">14:50</span><span class="showtime-pill">17:30</span><span class="showtime-pill">20:20</span></div>
                    <a class="btn btn-outline-dark btn-sm rounded-pill mt-3" asp-controller="Home" asp-action="Movie" asp-route-slug="mufasa-lion-king">Детальніше</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="movie-card h-100">
                    <img class="movie-poster" src="/images/posters/vaiana2.svg" alt="Афіша Ваяна 2">
                    <div class="p-3">
                    <h5 class="fw-bold">Ваяна 2</h5>
                    <div class="movie-meta mb-2">3D · Українська</div>
                    <div><span class="showtime-pill">14:00</span><span class="showtime-pill">18:45</span></div>
                    <a class="btn btn-outline-dark btn-sm rounded-pill mt-3" asp-controller="Home" asp-action="Movie" asp-route-slug="vaiana-2">Детальніше</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="movie-card h-100">
                    <img class="movie-poster" src="/images/posters/sonic3.svg" alt="Афіша Соник 3">
                    <div class="p-3">
                    <h5 class="fw-bold">Соник 3 / Їжак Сонік 3</h5>
                    <div class="movie-meta mb-2">3D та 2D · Українська</div>
                    <div><span class="showtime-pill">11:30</span><span class="showtime-pill">16:20</span><span class="showtime-pill">13:00</span><span class="showtime-pill">19:20</span></div>
                    <a class="btn btn-outline-dark btn-sm rounded-pill mt-3" asp-controller="Home" asp-action="Movie" asp-route-slug="sonic-3">Детальніше</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="movie-card h-100">
                    <img class="movie-poster" src="/images/posters/paddington3.svg" alt="Афіша Пригоди Падінгтона 3">
                    <div class="p-3">
                    <h5 class="fw-bold">Пригоди Падінгтона 3</h5>
                    <div class="movie-meta mb-2">3D · Українська</div>
                    <div><span class="showtime-pill">10:00</span></div>
                    <a class="btn btn-outline-dark btn-sm rounded-pill mt-3" asp-controller="Home" asp-action="Movie" asp-route-slug="paddington-3">Детальніше</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="movie-card h-100">
                    <img class="movie-poster" src="/images/posters/lotr-war.svg" alt="Афіша Володар перснів: Війна рогіримів">
                    <div class="p-3">
                    <h5 class="fw-bold">Володар перснів: Війна рогіримів</h5>
                    <div class="movie-meta mb-2">2D · Українська</div>
                    <div><span class="showtime-pill">20:40</span></div>
                    <a class="btn btn-outline-dark btn-sm rounded-pill mt-3" asp-controller="Home" asp-action="Movie" asp-route-slug="lotr-war-rohirrim">Детальніше</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="movie-card h-100">
                    <img class="movie-poster" src="/images/posters/family-pack.svg" alt="Афіша Леопольд, Єретик та Ще одна шалена п'ятниця">
                    <div class="p-3">
                    <h5 class="fw-bold">Леопольд / Єретик / Ще одна шалена п'ятниця</h5>
                    <div class="movie-meta mb-2">2D · Українська</div>
                    <div><span class="showtime-pill">13:50</span><span class="showtime-pill">17:00</span><span class="showtime-pill">16:40</span><span class="showtime-pill">18:20</span></div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a class="btn btn-outline-dark btn-sm rounded-pill" asp-controller="Home" asp-action="Movie" asp-route-slug="leopold">Леопольд</a>
                        <a class="btn btn-outline-dark btn-sm rounded-pill" asp-controller="Home" asp-action="Movie" asp-route-slug="heretic">Єретик</a>
                        <a class="btn btn-outline-dark btn-sm rounded-pill" asp-controller="Home" asp-action="Movie" asp-route-slug="freaky-friday-2">Шалена п'ятниця</a>
                    </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-5">
        <h2 class="section-title mb-3">Контакти</h2>
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="contact-box">
                    <p class="mb-1"><strong>Кінотеатр:</strong> Кінопалац Рівне</p>
                    <p class="mb-1"><strong>Адреса:</strong> м. Рівне, вул. Гагаріна, 26</p>
                    <p class="mb-1"><strong>Телефони:</strong> +380 (362) 22-22-00, +380 (67) 360-70-40</p>
                    <p class="mb-1"><strong>Email:</strong> kinopalace.rivne@gmail.com</p>
                    <p class="note mb-0">Графік роботи: без вихідних 11:00-22:00, каса працює до 21:00.</p>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="service-card">
                    <h5 class="fw-bold">Підказка</h5>
                    <p class="note mb-0">Детальніший розклад і купівля квитків доступні на офіційному сайті kino.rv.ua.</p>
                </div>
            </div>
        </div>
    </section>
</div>
