@model HomeIndexViewModel
@{
    ViewData["Title"] = "Головна";
}

<section class="hero-card p-4 p-lg-5 mb-4">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <span class="badge rounded-pill bg-warning-subtle text-dark mb-3">Навчальна MVC-платформа</span>
            <h1 class="display-5 fw-bold">Керування заняттями між репетитором та учнями</h1>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-primary" asp-controller="Lessons" asp-action="Index">Розклад занять</a>
                <a class="btn btn-outline-dark" asp-controller="Materials" asp-action="Index">Матеріали</a>
            </div>
        </div>
        <div class="col-lg-5 mt-4 mt-lg-0">
            <div class="stats-grid">
                <div class="stat-card"><div class="stat-label">Найближчі заняття</div><div class="stat-value">@Model.UpcomingLessons.Count</div></div>
                <div class="stat-card"><div class="stat-label">Домашні</div><div class="stat-value">@Model.HomeworkItems.Count</div></div>
                <div class="stat-card"><div class="stat-label">Доходи місяця</div><div class="stat-value">@(Model.TutorStats?.MonthlyIncome ?? 0) грн</div></div>
                <div class="stat-card"><div class="stat-label">Борг</div><div class="stat-value">@(Model.StudentStats?.OutstandingDebt ?? Model.TutorStats?.OutstandingDebt ?? 0) грн</div></div>
            </div>
        </div>
    </div>
</section>

@if (Model.TutorStats is not null)
{
    <section class="row g-3 mb-4">
        <div class="col-md-3"><div class="dashboard-tile"><div>Учні</div><strong>@Model.TutorStats.TotalStudents</strong></div></div>
        <div class="col-md-3"><div class="dashboard-tile"><div>Заплановані</div><strong>@Model.TutorStats.PlannedLessons</strong></div></div>
        <div class="col-md-3"><div class="dashboard-tile"><div>Невиконані ДЗ</div><strong>@Model.TutorStats.PendingHomework</strong></div></div>
        <div class="col-md-3"><div class="dashboard-tile"><div>Заборгованість</div><strong>@Model.TutorStats.OutstandingDebt грн</strong></div></div>
    </section>
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h4 mb-0">Найближчі заняття</h2>
                    <a asp-controller="Lessons" asp-action="Index">Усі</a>
                </div>
                <partial name="~/Views/Lessons/_LessonTable.cshtml" model="Model.UpcomingLessons" />
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h4 mb-0">Домашні завдання</h2>
                    <a asp-controller="Homework" asp-action="Index">Усі</a>
                </div>
                <div class="list-group list-group-flush">
                    @foreach (var item in Model.HomeworkItems)
                    {
                        <div class="list-group-item px-0">
                            <div class="fw-semibold">@item.Title</div>
                            <div class="small text-muted">@item.LessonSummary</div>
                            <div class="small">Статус: @item.Status</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
