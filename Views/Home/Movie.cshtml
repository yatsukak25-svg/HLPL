@model HLPL_lab_1.Models.MovieInfoViewModel
@{
    ViewData["Title"] = Model.Title;
}

<style>
    .movie-page {
        color: #f5f7fb;
    }

    .movie-hero {
        background: linear-gradient(135deg, rgba(21, 33, 61, 0.94), rgba(25, 56, 95, 0.88));
        border: 1px solid rgba(240, 187, 83, 0.28);
        border-radius: 24px;
        padding: 2rem;
        box-shadow: 0 20px 45px rgba(8, 8, 12, 0.28);
    }

    .movie-poster-lg {
        width: 100%;
        border-radius: 18px;
        object-fit: cover;
        max-height: 520px;
        background: #fff;
    }

    .movie-title {
        font-size: 2.2rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .movie-subtitle {
        color: #dbe3f2;
    }

    .movie-chip {
        background: rgba(255, 240, 205, 0.16);
        color: #fff5d7;
        border: 1px solid rgba(255, 228, 168, 0.3);
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        font-size: 0.85rem;
        display: inline-block;
        margin-right: 0.4rem;
        margin-bottom: 0.4rem;
    }

    .movie-card-light {
        background: #fffdf9;
        border-radius: 18px;
        padding: 1.25rem;
        color: #1e293b;
    }

    .label {
        color: #64748b;
        font-size: 0.9rem;
        margin-bottom: 0.2rem;
    }
</style>

<div class="container py-5 movie-page">
    <div class="movie-hero">
        <div class="row g-4 align-items-start">
            <div class="col-lg-4">
                <img class="movie-poster-lg" src="@Model.PosterPath" alt="Афіша @Model.Title">
            </div>
            <div class="col-lg-8">
                <div class="movie-title">@Model.Title</div>
                @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
                {
                    <div class="movie-subtitle mt-1">@Model.Subtitle</div>
                }

                <div class="mt-3">
                    <span class="movie-chip">@Model.Genre</span>
                    <span class="movie-chip">@Model.Duration</span>
                    <span class="movie-chip">@Model.AgeRating</span>
                    <span class="movie-chip">@Model.Format</span>
                </div>

                <p class="mt-4 mb-4">@Model.Description</p>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="movie-card-light h-100">
                            <div class="label">Мова</div>
                            <div class="fw-semibold">@Model.Language</div>
                            <div class="label mt-3">Країна / Рік</div>
                            <div class="fw-semibold">@Model.Country, @Model.Year</div>
                            <div class="label mt-3">Режисер</div>
                            <div class="fw-semibold">@Model.Director</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="movie-card-light h-100">
                            <div class="label">У ролях / Озвучення</div>
                            <div class="fw-semibold">@Model.Cast</div>
                            <div class="label mt-3">Найближчі сеанси</div>
                            <div class="d-flex flex-wrap gap-2 mt-1">
                                @foreach (var time in Model.Showtimes)
                                {
                                    <span class="badge text-bg-dark">@time</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <a class="btn btn-warning rounded-pill px-4" asp-controller="Home" asp-action="Schedule">До розкладу</a>
                    <a class="btn btn-outline-light rounded-pill px-4" asp-controller="Home" asp-action="Index">На головну</a>
                </div>
            </div>
        </div>
    </div>
</div>
