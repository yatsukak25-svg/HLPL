            <div class="col-lg-4" data-date="2026-01-02" data-format="3D" data-movie="Пригоди Падінгтона 3">
                <div class="session-card"><div class="session-time">10:00</div><div class="fw-bold">Пригоди Падінгтона 3</div><div class="session-meta">3D • Українська мова</div><div><span class="tag">3D</span><span class="tag">Сімейний</span></div><button class="buy-btn">Квиток</button></div>
            </div>
            <div class="col-lg-4" data-date="2026-01-02" data-format="2D" data-movie="Три коти. Зимові канікули">
                <div class="session-card"><div class="session-time">10:10</div><div class="fw-bold">Три коти. Зимові канікули</div><div class="session-meta">2D • Українська мова</div><div><span class="tag">2D</span><span class="tag">Анімація</span></div><button class="buy-btn">Квиток</button></div>
            </div>
            <div class="col-lg-4" data-date="2026-01-02" data-format="3D" data-movie="Соник 3">
                <div class="session-card"><div class="session-time">11:30</div><div class="fw-bold">Соник 3</div><div class="session-meta">3D • Українська мова</div><div><span class="tag">3D</span><span class="tag">Сімейний</span></div><button class="buy-btn">Квиток</button></div>
            </div>
            <div class="col-lg-4" data-date="2026-01-02" data-format="3D" data-movie="Муфаса: Король Лев">
