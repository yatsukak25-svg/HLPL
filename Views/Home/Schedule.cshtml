@{
    ViewData["Title"] = "Розклад сеансів";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:wght@400;600&display=swap');

    :root {
        --deep: #1e1a3a;
        --copper: #e86f4b;
        --gold: #f5c466;
        --ice: #eef6ff;
    }

    .schedule-hero {
        background: linear-gradient(120deg, rgba(30, 26, 58, 0.95), rgba(18, 18, 26, 0.92)), url('/img/noise.svg');
        color: #fff;
        border-radius: 24px;
        padding: 2.8rem;
        box-shadow: 0 20px 50px rgba(18, 18, 26, 0.28);
        margin-bottom: 2.5rem;
    }

    .schedule-title {
        font-family: "Bebas Neue", sans-serif;
        font-size: 2.8rem;
        letter-spacing: 0.12rem;
    }

    .schedule-subtitle {
        font-family: "Cormorant Garamond", serif;
        font-size: 1.2rem;
        max-width: 700px;
    }

    .filter-card {
        background: #ffffff;
        border-radius: 18px;
        padding: 1.5rem;
        box-shadow: 0 14px 35px rgba(30, 26, 58, 0.12);
    }

    .session-card {
        background: #ffffff;
        border-radius: 18px;
        padding: 1.2rem 1.4rem;
        border: 1px solid rgba(30, 26, 58, 0.08);
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .session-time {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--deep);
    }

    .session-meta {
        font-size: 0.95rem;
        color: #6a6f83;
    }

    .tag {
        background: var(--ice);
        color: var(--deep);
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
        font-size: 0.75rem;
        display: inline-block;
        margin-right: 0.35rem;
        margin-bottom: 0.35rem;
    }

    .buy-btn {
        background: var(--copper);
        color: #fff;
        border: none;
        padding: 0.4rem 1.1rem;
        border-radius: 999px;
        font-weight: 600;
        align-self: flex-start;
    }

    .buy-btn:hover {
        color: #fff;
        box-shadow: 0 8px 18px rgba(232, 111, 75, 0.3);
    }

    .date-pill {
        border: 1px solid rgba(30, 26, 58, 0.2);
        background: #fff;
        border-radius: 999px;
        padding: 0.35rem 0.8rem;
        cursor: pointer;
        font-size: 0.9rem;
    }

    .date-pill.active {
        background: var(--gold);
        border-color: var(--gold);
        color: #2b1e07;
        font-weight: 600;
    }

    .empty-state {
        background: #fff;
        border-radius: 18px;
        padding: 1.4rem;
        border: 1px dashed rgba(30, 26, 58, 0.2);
        color: #6a6f83;
        text-align: center;
    }

    .movie-link {
        color: inherit;
        text-decoration: none;
    }

    .movie-link:hover {
        text-decoration: underline;
    }
</style>

<div class="container py-5">
    <section class="schedule-hero">
        <div class="row align-items-center g-3">
            <div class="col-lg-8">
                <div class="schedule-title">Розклад сеансів</div>
                <p class="schedule-subtitle">
                    Дані заповнені з сайту kino.rv.ua (Кінопалац, Рівне): фільми, формати 2D/3D та часи показів.
                </p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <div class="fs-4 fw-bold" style="color: var(--gold);">П'ятниця, 2 січня</div>
                <div class="session-meta">Оновлено під дані kino.rv.ua</div>
            </div>
        </div>
    </section>

    <section class="mb-4">
