@section Scripts {
    <script>
        const movieSlugMap = {
            "Пригоди Падінгтона 3": "paddington-3",
            "Три коти. Зимові канікули": "three-cats-winter-vacation",
            "Соник 3": "sonic-3",
            "Їжак Сонік 3": "sonic-3",
            "Муфаса: Король Лев": "mufasa-lion-king",
            "Ваяна 2": "vaiana-2",
            "Володар перснів: Війна рогіримів": "lotr-war-rohirrim",
            "Леопольд": "leopold",
            "Єретик": "heretic",
            "Ще одна шалена п'ятниця": "freaky-friday-2"
        };

        const dateButtons = document.querySelectorAll('#dateFilters .date-pill');
        const formatSelect = document.getElementById('formatSelect');
        const movieSelect = document.getElementById('movieSelect');
        const sessions = document.querySelectorAll('#sessions > div');
        const emptyState = document.getElementById('emptyState');
        let activeDate = '2026-01-02';

        function applyFilters() {
            let visibleCount = 0;
            sessions.forEach(card => {
                const date = card.dataset.date;
                const format = card.dataset.format;
                const movie = card.dataset.movie;
                const formatMatch = formatSelect.value === 'all' || formatSelect.value === format;
                const movieMatch = movieSelect.value === 'all' || movieSelect.value === movie;
                const dateMatch = activeDate === date;
                const visible = formatMatch && movieMatch && dateMatch;
                card.style.display = visible ? '' : 'none';
                if (visible) { visibleCount += 1; }
            });
            emptyState.classList.toggle('d-none', visibleCount !== 0);
        }

        dateButtons.forEach(button => {
            button.addEventListener('click', () => {
                dateButtons.forEach(btn => btn.classList.remove('active'));
                button.classList.add('active');
                activeDate = button.dataset.date;
                applyFilters();
            });
        });

        sessions.forEach(card => {
            const movieTitleEl = card.querySelector('.fw-bold');
            if (!movieTitleEl) { return; }
            const title = movieTitleEl.textContent?.trim();
            const slug = title ? movieSlugMap[title] : null;
            if (!slug) { return; }
            movieTitleEl.innerHTML = `<a class="movie-link" href="/Home/Movie?slug=${slug}">${title}</a>`;
        });

        formatSelect.addEventListener('change', applyFilters);
        movieSelect.addEventListener('change', applyFilters);

        applyFilters();
    </script>
}
