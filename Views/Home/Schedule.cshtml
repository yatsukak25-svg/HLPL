                    </div>
                </div>
                <div class="col-lg-3">
                    <label class="fw-bold mb-2" for="formatSelect">Формат</label>
                    <select class="form-select" id="formatSelect">
                        <option value="all">Будь-який</option>
                        <option value="2D">2D</option>
                        <option value="3D">3D</option>
                    </select>
                </div>
                <div class="col-lg-4">
                    <label class="fw-bold mb-2" for="movieSelect">Фільм</label>
                    <select class="form-select" id="movieSelect">
                        <option value="all">Усі фільми</option>
                        <option value="Пригоди Падінгтона 3">Пригоди Падінгтона 3</option>
                        <option value="Три коти. Зимові канікули">Три коти. Зимові канікули</option>
                        <option value="Соник 3">Соник 3</option>
                        <option value="Їжак Сонік 3">Їжак Сонік 3</option>
                        <option value="Муфаса: Король Лев">Муфаса: Король Лев</option>
                        <option value="Ваяна 2">Ваяна 2</option>
                        <option value="Володар перснів: Війна рогіримів">Володар перснів: Війна рогіримів</option>
                        <option value="Леопольд">Леопольд</option>
                        <option value="Єретик">Єретик</option>
                        <option value="Ще одна шалена п'ятниця">Ще одна шалена п'ятниця</option>
                    </select>
                </div>
            </div>
        </div>
    </section>

    <section>
