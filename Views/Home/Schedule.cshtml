                <div class="session-card"><div class="session-time">17:00</div><div class="fw-bold">Леопольд</div><div class="session-meta">2D • Українська мова</div><div><span class="tag">2D</span><span class="tag">Сімейний</span></div><button class="buy-btn">Квиток</button></div>
            </div>
