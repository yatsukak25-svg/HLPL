@model IReadOnlyList<HomeworkDto>
@{
    ViewData["Title"] = "Домашні завдання";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Домашні завдання</h1>
    <a class="btn btn-primary" asp-action="Create">Додати</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <table class="table align-middle">
            <thead><tr><th>Назва</th><th>Заняття</th><th>Дедлайн</th><th>Статус</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.LessonSummary</td>
                    <td>@item.Deadline.ToString("dd.MM.yyyy")</td>
                    <td>@item.Status</td>
                    <td class="text-end">
                        @if (User.IsInRole("Student"))
                        {
                            <form asp-action="Submit" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button class="btn btn-sm btn-outline-success" type="submit">Позначити виконаним</button>
                            </form>
                        }
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Редагувати</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Видалити</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
