@model HomeworkFormViewModel

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h1 class="h4 mb-3">@ViewData["Title"]</h1>
        <form method="post">
            <input type="hidden" asp-for="Homework.Id" />
            <div class="row g-3">
                <div class="col-md-6"><label asp-for="Homework.LessonId" class="form-label"></label><select asp-for="Homework.LessonId" asp-items="Model.Lessons" class="form-select"></select></div>
                <div class="col-md-6"><label asp-for="Homework.Title" class="form-label"></label><input asp-for="Homework.Title" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="Homework.Deadline" class="form-label"></label><input asp-for="Homework.Deadline" type="date" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="Homework.Status" class="form-label"></label><select asp-for="Homework.Status" asp-items="Html.GetEnumSelectList<HomeworkStatus>()" class="form-select"></select></div>
                <div class="col-md-4"><label asp-for="Homework.FileUrl" class="form-label"></label><input asp-for="Homework.FileUrl" class="form-control" /></div>
                <div class="col-12"><label asp-for="Homework.Description" class="form-label"></label><textarea asp-for="Homework.Description" class="form-control" rows="4"></textarea></div>
            </div>
            <div class="mt-3"><button class="btn btn-primary" type="submit">Зберегти</button> <a class="btn btn-outline-secondary" asp-action="Index">Назад</a></div>
        </form>
    </div>
</div>
<partial name="_ValidationScriptsPartial" />
