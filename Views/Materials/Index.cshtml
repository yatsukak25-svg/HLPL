@model MaterialsIndexViewModel
@{
    ViewData["Title"] = "Матеріали";
}

<h1 class="h3 mb-3">Навчальні матеріали</h1>
<div class="row g-3">
@foreach (var item in Model.Materials)
{
    var selected = Model.SelectedMaterialIds.Contains(item.Id);
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small text-muted">@item.SubjectName</div>
                        <h2 class="h5">@item.Title</h2>
                    </div>
                    @if (selected)
                    {
                        <span class="badge bg-success">Обрано</span>
                    }
                </div>
                <p>@item.Description</p>
                <a href="@item.Url" target="_blank" class="btn btn-outline-dark btn-sm">Відкрити</a>
                <form asp-action="ToggleSelected" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@item.Id" />
                    <button class="btn btn-sm @(selected ? "btn-outline-danger" : "btn-outline-primary")" type="submit">@(selected ? "Прибрати" : "Обрати")</button>
                </form>
            </div>
        </div>
    </div>
}
</div>
