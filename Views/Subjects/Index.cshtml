@model IReadOnlyList<SubjectDto>
@{
    ViewData["Title"] = "Предмети";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Предмети</h1>
    <a class="btn btn-primary" asp-action="Create">Додати предмет</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <table class="table align-middle">
            <thead><tr><th>Назва</th><th>Опис</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Редагувати</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Видалити</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
